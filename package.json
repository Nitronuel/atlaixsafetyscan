{
  "name": "safety-scan",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n ENGINE,APP -c cyan,green \"npm:dev:engine\" \"npm:dev:web\"",
    "dev:web": "vite",
    "dev:engine": "tsx server/insightx-server.ts",
    "start:engine": "tsx server/insightx-server.ts",
    "build": "vite build",
    "preview": "vite preview",
    "deploy:netlify": "npm run build && netlify deploy --prod --dir=dist --functions=netlify/functions"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.0",
    "d3-force": "^3.0.0",
    "geist": "^1.7.1",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tsx": "^4.20.5",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/d3-force": "^3.0.10",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.2"
  }
}
